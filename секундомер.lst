 0012				Prepfunc PROC ;функциональная подготовка
				            ;сброс прошлых образов портов
 0012  C6 06 0003 R FF		            mov LastTrackImg, 0ffh
 0017  C6 06 0001 R FF		            mov LastBttnImg, 0ffh
				            ;сброс флага работы секундомера
 001C  C6 06 0007 R 00		            mov StartFlag, 0
				            ;обнуление времени
 0021  C7 06 000C R 0000	            mov word ptr Time, 0
 0027  C7 06 000E R 0000	            mov word ptr Time+2, 0
				            ;обнуление массива результатов
 002D  B9 0050			            mov cx, RaceLen * TrackLen * ResultsLen / 2
 0030  8D 36 0010 R		            lea si, Results
 0034  C7 04 0000		 pfres:     mov word ptr [si], 0
 0038  83 C6 02			            add si, 2
 003B  E2 F7			            loop pfres
				            ;сброс флагов
 003D  C6 06 0004 R 00		            mov TrackEndFlag, 0
 0042  C6 06 0006 R 00		            mov RaceErrFlag, 0
 0047  C6 06 0005 R 00		            mov TimeErrFlag,0
 004C  C6 06 0008 R 00		            mov DispModeFlag, 0
				            ;обнуление номеров забега и дорожек
 0051  C6 06 0009 R FF		            mov CurrRace, -1
 0056  C6 06 000A R 00		            mov DispRace, 0
 005B  C6 06 000B R 00		            mov DispTrack, 0

 0060				Prepfunc  ENDP

