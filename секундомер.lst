 00A6				TimeForm PROC ;отсчет времени
				            ;срабатывает по прерыванию таймера
				            ;сохранение состояний регистра
 00A6  50			            push ax
				            ;проверка состояния секундомера
 00A7  80 3E 0007 R FF		            cmp StartFlag, 0ffh
 00AC  75 45			            jnz tfexit ; переход если остановлен
				            ;инкремент времени
				            ;обработка миллисекунд
 00AE  A0 000F R		            mov al, Time+3
 00B1  04 01			            add al, 1
 00B3  27			            daa
 00B4  A2 000F R		            mov Time+3, al
				            ;обработка секунд
 00B7  A0 000E R		            mov al, Time+2
 00BA  14 00			            adc al, 0
 00BC  27			            daa
 00BD  A2 000E R		            mov Time+2, al
 00C0  C0 E8 04			            shr al, 4
 00C3  3C 05			            cmp al, 5
 00C5  76 2C			            jna tfexit ;выход если переноса нет
 00C7  C6 06 000E R 00		            mov Time+2, 0
				            ;обработка минут
 00CC  A0 000D R		            mov al, Time+1
 00CF  04 01			            add al, 1
 00D1  27			            daa
 00D2  A2 000D R		            mov Time+1, al
 00D5  C0 E8 04			            shr al, 4
 00D8  3C 05			            cmp al, 5
 00DA  76 17			            jna tfexit ;выход если переноса нет
 00DC  C6 06 000D R 00		            mov Time+1, 0
				            ;обработка часов
 00E1  FE 06 000C R		            inc Time
 00E5  80 3E 000C R 09		            cmp Time, 9
 00EA  76 07			            jna tfexit
 00EC  C6 06 0005 R FF		            mov TimeErrFlag, 0ffh
 00F1  EB 00			            jmp tfexit
 00F3				 tfexit:    
				            ;восстановление состояний регистров
 00F3  58			            pop ax
 00F4  CF			            iret
 00F5				TimeForm ENDP

 00F5				StartForm PROC ;формирование флага работы секундомера
				            ;проверка ошибок
 00F5  A0 0006 R		            mov al, RaceErrFlag
 00F8  0A 06 0005 R		            or al, TimeErrFlag
 00FC  3C FF			            cmp al, 0ffh
 00FE  75 07			            jnz sf_err_skip; переход если ошибок нет
 0100  C6 06 0007 R 00		            mov StartFlag, 0 ;остановка секундомера
 0105  EB 39			            jmp sfexit
 0107				 sf_err_skip:            
				            ;проверка состояния секундомера
 0107  80 3E 0007 R FF		            cmp StartFlag, 0ffh
 010C  75 15			            jnz sf_not_started  ;переход если секундомер стоит
				            
				            ;секундомер идет
				            ;проверка если все дорожки уже сработали
				            ;обновление флага срабатывания дорожек
 010E  A0 0002 R		            mov al, TrackPortImg 
 0111  08 06 0004 R		            or TrackEndFlag, al
 0115  80 3E 0004 R FF		            cmp TrackEndFlag, 0ffh ;проверка флага
 011A  75 24			            jnz sfexit ;выход если не все дорожки сработали
 011C  C6 06 0007 R 00		            mov StartFlag, 0;остановка секундомера
 0121  EB 1D			            jmp sfexit
 0123				 sf_not_started:
				            ;секундомер стоит
 0123  C6 06 0004 R 00		            mov TrackEndFlag, 0 ;обнуление флага сработавших дорожек
				            ;проверка кнопки старта
 0128  F6 06 0000 R 01		            test BttnPortImg, 01 ;0000 0001
 012D  74 11			            jz  sfexit;выход если кнопка не нажата
				            ;обнуление таймера
 012F  C7 06 000C R 0000	            mov word ptr Time, 0
 0135  C7 06 000E R 0000	            mov word ptr Time+2, 0
 013B  C6 06 0007 R FF		            mov StartFlag, 0ffh;запуск секундомера
 0140				 sfexit:
 0140  C3			            ret
 0141				StartForm ENDP

 0141				RaceNumForm PROC ;формирование номера забега
				            ;проверка состояния секундомера
 0141  80 3E 0007 R FF		            cmp StartFlag, 0ffh
 0146  74 36			            jz rnfexit ;выход если секундомер идет
				            ;проверка кнопки старт
 0148  F6 06 0000 R 01		            test BttnPortImg, 01 ;0000 0001
 014D  74 18			            jz  rnf_start_skip
				            ;кнопка нажата
				            ;увеличение текущего забега
 014F  FE 06 0009 R		            inc CurrRace
				            ;смена отображаемого забега
 0153  A0 0009 R		            mov al, CurrRace
 0156  A2 000A R		            mov DispRace, al
				            ;проверка ошибки переполения забегов
 0159  80 3E 0009 R 04		            cmp CurrRace, 4
 015E  75 05			            jnz rnf_err_skip
 0160  C6 06 0006 R FF		            mov RaceErrFlag, 0ffh ;поднятие флага ошибки забегов
 0165				 rnf_err_skip:
 0165  EB 17			            jmp rnfexit
 0167				 rnf_start_skip:
				            ;кнопка старт не нажата
				            ;проверка кнопки след. забега
 0167  F6 06 0000 R 04		            test BttnPortImg, 04 ;0000 0100
 016C  74 10			            jz  rnfexit
				            ;отображение след. забега
 016E  FE 06 000A R		            inc DispRace
				            ;зацикливание больше 4 забегов
 0172  80 3E 000A R 04		            cmp DispRace, 4
 0177  75 05			            jnz rnfexit
 0179  C6 06 000A R 00		            mov DispRace, 0
 017E				 rnfexit:
 017E  C3			            ret
 017F				RaceNumForm ENDP

 017F				TrackNumForm PROC;формирование номера дорожки
				            ;проверка состояния секундомера
 017F  80 3E 0007 R FF		            cmp StartFlag, 0ffh
 0184  74 17			            jz tnfexit ;выход если секундомер идет
