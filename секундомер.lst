				            ;выбор индикатора секунд
 021C  B0 DF			            mov al, 0DFh ;1101 1111
 021E  E6 02			            out ChoicePort, al
				            ;выключение всех индикаторов
 0220  B0 FF			            mov al, 0ffh
 0222  E6 02			            out ChoicePort, al

 0224				 ctdexit:
 0224  C3			            ret
 0225				CurrTimeDisp ENDP

