 019E				DispModeChange PROC ;смена режима отображения
				            ;проверка состояния секундомера
 019E  80 3E 0007 R FF		            cmp StartFlag, 0ffh
 01A3  75 07			            jnz dmcpaused
				            ;секундомер идет
 01A5  C6 06 0008 R 00		            mov DispModeFlag, 0 ;режим отображения тек. времени
 01AA  EB 0C			            jmp dmcexit
 01AC				 dmcpaused: 
				            ;секундомер стоит
				            ;проверка срабатывания всех дорожек
				            ;(т.е. секундомер только что остановился)
 01AC  80 3E 0004 R FF		            cmp TrackEndFlag, 0ffh
 01B1  75 05			            jnz dmcexit
 01B3  C6 06 0008 R FF		            mov DispModeFlag, 0ffh ;режим отображения результатов
 01B8				 dmcexit:
 01B8  C3			            ret
 01B9				DispModeChange ENDP

 01B9				CurrTimeDisp PROC ;отображение текущего времени
				            ;проверка ошибок
 01B9  A0 0006 R		            mov al, RaceErrFlag
 01BC  0A 06 0005 R		            or al, TimeErrFlag
 01C0  3C FF			            cmp al, 0ffh
 01C2  74 60			            jz ctdexit
				            ;проверка режима отображения 
 01C4  80 3E 0008 R FF		            cmp DispModeFlag, 0ffh
 01C9  74 59			            jz ctdexit ;если режим отображ резуль. то выход
				            ;подготовка массива образов 
 01CB  8D 1E 0000 R		            lea  bx, digits
				            ;статический вывод номера забега
 01CF  A0 0009 R		            mov al, CurrRace
 01D2  FE C0			            inc al
 01D4  2E: D7			            xlat digits
 01D6  E6 03			            out RaceDispPort, al

				            ;динамический вывод времени
				            ;подготовка регистра для выбора индикаторов
 01D8  B4 FD			            mov ah, 0FDh ; 1111 1101

				            ;вывод цифры часов
				            ;чтение часов
 01DA  A0 000C R		            mov al, Time
				            ;табличное преобразование в образ
 01DD  2E: D7			            xlat digits
				            ;вывод на индикатоор
 01DF  E6 01			            out SegPort, al
				            ;включение индикатора часов
 01E1  8A C4			            mov al, ah
 01E3  E6 02			            out ChoicePort, al
				            ;выключение всех индикаторов
 01E5  B0 FF			            mov al, 0ffh
 01E7  E6 02			            out ChoicePort, al
				            ;сдвиг регистра выбора индикаторов
				            ;rol ah, 1
				            ;подготовка цикла
 01E9  B9 0003			            mov cx, 3
 01EC  8D 36 000D R		            lea si, Time + 1
 01F0				 ctd_loop:
				            ;сдвиг регистра выбора индикаторов
 01F0  D0 C4			            rol ah, 1
				            ;выделение старшей цифры числа
 01F2  8A 04			            mov al, [si]
 01F4  C0 E8 04			            shr al, 4
				            ;табличное преобразование в образ
 01F7  2E: D7			            xlat digits
				            ;вывод на индикатоор
 01F9  E6 01			            out SegPort, al
				            ;выбор старшего индикатора
 01FB  8A C4			            mov al, ah
 01FD  E6 02			            out ChoicePort, al
				            ;выключение всех индикаторов
 01FF  B0 FF			            mov al, 0ffh
 0201  E6 02			            out ChoicePort, al

				            ;сдвиг регистра выбора индикаторов
 0203  D0 C4			            rol ah, 1
				            ;выделение младшей цифры числа
 0205  8A 04			            mov al, [si]
 0207  24 0F			            and al, 0fh
				            ;табличное преобразование в образ
 0209  2E: D7			            xlat digits
				            ;вывод на индикатоор
 020B  E6 01			            out SegPort, al
				            ;выбор младшего индикатора
 020D  8A C4			            mov al, ah
 020F  E6 02			            out ChoicePort, al
				            ;выключение всех индикаторов
 0211  B0 FF			            mov al, 0ffh
 0213  E6 02			            out ChoicePort, al

				            ;модификация адреса источника
 0215  46			            inc si
 0216  E2 D8			            loop ctd_loop

				            ;вывод точки после секунд
 0218  B0 80			            mov al, 80h;1000 0000
